  <!-- fix the ur robot in place -->
  <joint name="world_to_UR2_pillar" type="fixed">
    <origin rpy="0 0 1.57" xyz="1.25 -0.70 0.35"/>
    <parent link="world"/>
    <child link="UR2_support_pillar"/>
  </joint>
  <!-- <joint name="pillar_to_$(arg prefix_2)base" type="fixed">
