      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0030531654454" ixy="0.0" ixz="0.0" iyy="0.0030531654454" iyz="0.0" izz="0.005625"/>
    </inertial>
  </link>
  <link name="UR2_shoulder_link">
    <visual>
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/shoulder.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/shoulder.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.98"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.008012231795105998" ixy="0.0" ixz="0.0" iyy="0.008012231795105998" iyz="0.0" izz="0.00556875"/>
    </inertial>
  </link>
  <link name="UR2_upper_arm_link">
    <visual>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.12"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/upperarm.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.12"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/upperarm.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.4445"/>
      <origin rpy="0 1.5707963267948966 0" xyz="-0.121825 0.0 0.12"/>
      <inertia ixx="0.021884140483944475" ixy="0.0" ixz="0.0" iyy="0.021884140483944475" iyz="0.0" izz="0.00968765625"/>
    </inertial>
  </link>
  <link name="UR2_forearm_link">
    <visual>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.027"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/forearm.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.027"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/forearm.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.437"/>
      <origin rpy="0 1.5707963267948966 0" xyz="-0.1066 0.0 0.027"/>
      <inertia ixx="0.0074639235044294035" ixy="0.0" ixz="0.0" iyy="0.0074639235044294035" iyz="0.0" izz="0.0040415625"/>
    </inertial>
  </link>
  <link name="UR2_wrist_1_link">
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.104"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/wrist1.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.104"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/wrist1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.871"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0022700428419824997" ixy="0.0" ixz="0.0" iyy="0.0022700428419824997" iyz="0.0" izz="0.0024496874999999996"/>
    </inertial>
  </link>
  <link name="UR2_wrist_2_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.08535"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/wrist2.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.08535"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/wrist2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.805"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0020980304107875002" ixy="0.0" ixz="0.0" iyy="0.0020980304107875002" iyz="0.0" izz="0.0022640625"/>
    </inertial>
  </link>
  <link name="UR2_wrist_3_link">
    <visual>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.0921"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/wrist3.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.0921"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/wrist3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.261"/>
      <origin rpy="0 0 0" xyz="0.0 0.0 -0.02"/>
      <inertia ixx="0.0001016159593536" ixy="0.0" ixz="0.0" iyy="0.0001016159593536" iyz="0.0" izz="0.000133632"/>
    </inertial>
  </link>
  <!-- base_joint fixes base_link to the environment -->
  <joint name="UR2_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0.15 0.35"/>
    <parent link="UR2_support_pillar"/>
    <child link="UR2_base_link"/>
  </joint>
  <!-- joints - main serial chain -->
  <joint name="UR2_base_link-base_link_inertia" type="fixed">
    <parent link="UR2_base_link"/>
    <child link="UR2_base_link_inertia"/>
    <!-- 'base_link' is REP-103 aligned (so X+ forward), while the internal
           frames of the robot/controller have X+ pointing backwards.
           Use the joint between 'base_link' and 'base_link_inertia' (a dummy
           link/frame) to introduce the necessary rotation over Z (of pi rad).
      -->
    <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
  </joint>
  <joint name="UR2_shoulder_pan_joint" type="revolute">
    <parent link="UR2_base_link_inertia"/>
    <child link="UR2_shoulder_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.15185"/>
    <axis xyz="0 0 1"/>
    <limit effort="56.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-6.133185307179586" soft_upper_limit="6.133185307179586"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <joint name="UR2_shoulder_lift_joint" type="revolute">
    <parent link="UR2_shoulder_link"/>
    <child link="UR2_upper_arm_link"/>
    <origin rpy="1.570796327 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="56.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-6.133185307179586" soft_upper_limit="6.133185307179586"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <joint name="UR2_elbow_joint" type="revolute">
    <parent link="UR2_upper_arm_link"/>
    <child link="UR2_forearm_link"/>
    <origin rpy="0 0 0" xyz="-0.24355 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="28.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.141592653589793"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-2.991592653589793" soft_upper_limit="2.991592653589793"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <joint name="UR2_wrist_1_joint" type="revolute">
    <parent link="UR2_forearm_link"/>
    <child link="UR2_wrist_1_link"/>
    <origin rpy="0 0 0" xyz="-0.2132 0 0.13105"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="6.283185307179586"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-6.133185307179586" soft_upper_limit="6.133185307179586"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <joint name="UR2_wrist_2_joint" type="revolute">
    <parent link="UR2_wrist_1_link"/>
    <child link="UR2_wrist_2_link"/>
    <origin rpy="1.570796327 0 0" xyz="0 -0.08535 -1.750557762378351e-11"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="6.283185307179586"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-6.133185307179586" soft_upper_limit="6.133185307179586"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <joint name="UR2_wrist_3_joint" type="revolute">
    <parent link="UR2_wrist_2_link"/>
    <child link="UR2_wrist_3_link"/>
    <origin rpy="1.570796326589793 3.141592653589793 3.141592653589793" xyz="0 0.0921 -1.8890025766262e-11"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="6.283185307179586"/>
    <safety_controller k_position="20" k_velocity="0.0" soft_lower_limit="-6.133185307179586" soft_upper_limit="6.133185307179586"/>
    <dynamics damping="0" friction="0"/>
  </joint>
  <link name="UR2_ft_frame"/>
  <joint name="UR2_wrist_3_link-ft_frame" type="fixed">
    <parent link="UR2_wrist_3_link"/>
    <child link="UR2_ft_frame"/>
    <origin rpy="3.141592653589793 0 0" xyz="0 0 0"/>
  </joint>
  <!-- ROS-Industrial 'base' frame - base_link to UR 'Base' Coordinates transform -->
  <link name="UR2_base"/>
  <joint name="UR2_base_link-base_fixed_joint" type="fixed">
    <!-- Note the rotation over Z of pi radians - as base_link is REP-103
           aligned (i.e., has X+ forward, Y+ left and Z+ up), this is needed
           to correctly align 'base' with the 'Base' coordinate system of
           the UR controller.
      -->
    <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
    <parent link="UR2_base_link"/>
    <child link="UR2_base"/>
  </joint>
  <!-- ROS-Industrial 'flange' frame - attachment point for EEF models -->
  <link name="UR2_flange"/>
  <joint name="UR2_wrist_3-flange" type="fixed">
    <parent link="UR2_wrist_3_link"/>
    <child link="UR2_flange"/>
    <origin rpy="0 -1.5707963267948966 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <!-- ROS-Industrial 'tool0' frame - all-zeros tool frame -->
  <link name="UR2_tool0"/>
  <joint name="UR2_flange-tool0" type="fixed">
    <!-- default toolframe - X+ left, Y+ up, Z+ front -->
    <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
    <parent link="UR2_flange"/>
    <child link="UR2_tool0"/>
  </joint>
  <link name="UR2_quick_change_robot_side">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="-1.5708 0 -1.5708" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/divyam/four_ur_ws/install/ur_four/share/ur_four/onrobot_sg/models/common/Quick_Changer_RobotSide_v2.dae" scale="1 1 1"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.008"/>
      <geometry>
        <cylinder length="0.015" radius="0.045"/>
      </geometry>
    </collision>
  </link>
  <link name="UR2_gripper">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual name="UR2_gripper">
      <origin rpy="3.1415 -1.5708 0" xyz="0.0075 0.0055 0 "/>
      <geometry>
        <mesh filename="file:///home/divyam/four_ur_ws/install/ur_four/share/ur_four/onrobot_sg/models/onrobot_sg_b/meshes/SG-b_v1.dae" scale="1 1 1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry>
        <cylinder length="0.10" radius="0.049"/>
        <!-- Still doesn't cover full gripper length, but we need to dip and cover objects to grasp, so left some room-->
      </geometry>
    </collision>
  </link>
  <joint name="UR2_quick_changer_to_gripper" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.024"/>
    <parent link="UR2_quick_change_robot_side"/>
    <child link="UR2_gripper"/>
  </joint>
  <!-- <link name="world" /> -->
  <link name="UR2_support_pillar">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.38299" ixy="0" ixz="0" iyy="31.09613" iyz="0" izz="31.47895"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.68 0.5 0.7"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.68 0.5 0.7"/>
      </geometry>
    </collision>
  </link>
  <link name="UR2_rear_pillar_v1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
