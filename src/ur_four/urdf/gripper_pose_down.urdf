  <disable_collisions link1="UR2_tool0" link2="UR2_quick_change_robot_side" reason="Adjacent"/>








 
 
  <link name="UR1_base_link"/>
  <link name="UR1_base_link_inertia">
    <visual>
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/visual/base.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///opt/ros/jazzy/share/ur_description/meshes/ur3e/collision/base.stl"/>
      </geometry>
    </collision>
    <inertial>
