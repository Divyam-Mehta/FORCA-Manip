  <!-- Plugins for simulating onion grabbing -->

  <gazebo>

    <plugin name="gz::sim::systems::DynamicDetachableJoint"
            filename="libgz-sim-dynamic_detachable_joint-system.so">
      <parent_link>UR1_wrist_3_link</parent_link>
      <service_name>/ddj/UR1_wrist_3_link</service_name>
      <output_topic>/ddj/UR1_wrist_3_link/state</output_topic>
      <attach_distance>1.0</attach_distance>
    </plugin>

    <plugin name="gz::sim::systems::DynamicDetachableJoint"
            filename="libgz-sim-dynamic_detachable_joint-system.so">
      <parent_link>UR2_wrist_3_link</parent_link>
      <service_name>/ddj/UR2_wrist_3_link</service_name>
      <output_topic>/ddj/UR2_wrist_3_link/state</output_topic>
      <attach_distance>1.0</attach_distance>
    </plugin>

    <plugin name="gz::sim::systems::DynamicDetachableJoint"
            filename="libgz-sim-dynamic_detachable_joint-system.so">
      <parent_link>UR3_wrist_3_link</parent_link>
